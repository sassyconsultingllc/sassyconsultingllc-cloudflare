name = "sassyconsultingllc"
main = "src/worker.js"
compatibility_date = "2024-09-23"
account_id = "d5ccd0d80780f2d0ab72ab12b15244e2"

[assets]
directory = "./public"

# D1 Database
[[d1_databases]]
binding = "DB"
database_name = "contact-submissions"
database_id = "4d917d6a-8d9a-40cd-86a2-c69989cdf454"

# R2 Storage for downloads
[[r2_buckets]]
binding = "DOWNLOADS"
bucket_name = "sassy-downloads"

# Durable Objects for real-time PTT relay
[durable_objects]
bindings = [
    { name = "PTT_ROOMS", class_name = "PttRoom" }
]

[[migrations]]
tag = "v1_pttroom"
new_sqlite_classes = ["PttRoom"]

# Environment variables (non-secret)
[vars]
SITE_URL = "https://sassyconsultingllc.com"
MYBESTSITES_URL = "https://mybestsites.online"

# Secrets (add via: wrangler secret put SECRET_NAME)
# Required secrets:
# - STRIPE_SECRET_KEY
# - STRIPE_WEBHOOK_SECRET
# - STRIPE_PRICE_SASSY_TALK
# - STRIPE_PRICE_WINFORENSICS
# - STRIPE_PRICE_WEBSITE_CREATOR
# - LICENSE_SALT
# - RESEND_API_KEY (for email via Resend)
